# Blindseeker v1.0.0 - Environment Configuration

# Flask Secret Key (CHANGE THIS IN PRODUCTION)
SECRET_KEY=blindseeker-change-this-secret-key-in-production

# Server Configuration
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# Tor Configuration
TOR_ENABLED=false
TOR_SOCKS_HOST=127.0.0.1
TOR_SOCKS_PORT=9050
TOR_CONTROL_PORT=9051
TOR_CONTROL_PASSWORD=

# Proxy Configuration
PROXY_ENABLED=false
PROXY_FILE=proxies.txt
PROXY_ROTATION=true

# Scan Configuration
MAX_WORKERS=50
REQUEST_TIMEOUT=15
RATE_LIMIT_PER_SECOND=10
MAX_RETRIES=2

# Export Configuration
DEFAULT_EXPORT_FORMAT=json
EXPORT_DIR=exports

# Logging
LOG_LEVEL=INFO
LOG_FILE=blindseeker.log
